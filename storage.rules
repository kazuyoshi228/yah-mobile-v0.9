rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Static assets (fonts, videos, images) - read-only for frontend
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }


    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
